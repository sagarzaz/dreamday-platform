{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext", // Next.js expects ES modules
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    // Only include Node types for the tsc build; Next/React types are
    // brought in via their own packages when the modules are imported.
    // Listing other libraries caused errors (e.g. missing 'react-dom' types).
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
